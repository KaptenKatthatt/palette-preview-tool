{
  "name": "palette-preview-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "serve:dist": "node scripts/static-server.cjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "type-coverage": "type-coverage -p tsconfig.app.json --at-least 100 --detail",
    "check": "npm-run-all2 lint typecheck type-coverage"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/literata": "^5.2.6",
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.61.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
